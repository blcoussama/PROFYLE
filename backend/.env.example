# ==========================================
# APPLICATION
# ==========================================
NODE_ENV=development
PORT=3000

# ==========================================
# DATABASES
# ==========================================
# MongoDB (Users, Messages)
MONGODB_URI=mongodb://localhost:27017/profyle

# PostgreSQL via Prisma (Companies, Jobs, Applications, SavedJobs)
DATABASE_URL=postgresql://user:password@localhost:5432/profyle?schema=public

# ==========================================
# JWT
# ==========================================
JWT_ACCESS_SECRET=your_access_secret_minimum_32_characters_here
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_characters_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ==========================================
# AWS S3 (File Storage)
# ==========================================
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_BUCKET_NAME=profyle-uploads

# ==========================================
# EMAIL (Nodemailer SMTP)
# ==========================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@profyle.com

# ==========================================
# FRONTEND URL (CORS)
# ==========================================
CLIENT_URL=http://localhost:5173
